# CampusRent backend production example
# Copy this file to backend/.env on your EC2 server and replace every placeholder.

PORT=5000
NODE_ENV=production
FRONTEND_URL=https://YOUR_FRONTEND_HOST
CORS_ORIGINS=https://YOUR_FRONTEND_HOST
DATABASE_URL=postgresql://DB_USERNAME:DB_PASSWORD@RDS_ENDPOINT:5432/campusrent?schema=public
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=REPLACE_WITH_IAM_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_IAM_SECRET_ACCESS_KEY
S3_BUCKET_NAME=campusrent-uploads
SES_FROM_EMAIL=verified-sender@example.com
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=replace_with_razorpay_webhook_secret

LATE_FEE_PER_DAY=5
DUE_REMINDER_WINDOW_HOURS=24
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
